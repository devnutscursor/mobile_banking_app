<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed: subtle depress with scale and raised translationZ -->
    <item android:state_pressed="true">
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="150"
                android:valueFrom="0"
                android:valueTo="8"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="150"
                android:valueFrom="1"
                android:valueTo="0.98"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="150"
                android:valueFrom="1"
                android:valueTo="0.98"
                android:valueType="floatType" />
        </set>
    </item>

    <!-- Default state: relax back to normal -->
    <item>
        <set>
            <objectAnimator
                android:propertyName="translationZ"
                android:duration="200"
                android:valueFrom="8"
                android:valueTo="0"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleX"
                android:duration="200"
                android:valueFrom="0.98"
                android:valueTo="1"
                android:valueType="floatType" />
            <objectAnimator
                android:propertyName="scaleY"
                android:duration="200"
                android:valueFrom="0.98"
                android:valueTo="1"
                android:valueType="floatType" />
        </set>
    </item>
</selector>






