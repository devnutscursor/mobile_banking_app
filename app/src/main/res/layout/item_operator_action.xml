<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/glass_action_card"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvActionName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="16sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/ivEdit"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvActionType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_below="@id/tvActionName"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_toStartOf="@+id/ivEdit"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvUssdTemplate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            android:layout_below="@id/tvActionType"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_toStartOf="@+id/ivEdit"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:id="@+id/ivEdit"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:src="@drawable/ic_edit"
            android:tint="@color/text_primary"
            android:contentDescription="@string/edit" />

        <ImageView
            android:id="@+id/ivDelete"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_below="@id/ivEdit"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_delete"
            android:tint="@color/text_primary"
            android:contentDescription="@string/delete" />

    </RelativeLayout>

</androidx.cardview.widget.CardView>





