<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/terms_and_privacy_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/primary_purple"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/terms_and_privacy_message"
        android:textSize="14sp"
        android:textColor="@android:color/black"
        android:layout_marginBottom="16dp" />

    <!-- Scrollable Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:maxHeight="400dp"
        android:background="@android:color/white"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Terms of Use Section -->
            <TextView
                android:id="@+id/tvTermsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/terms_of_use"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_purple"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvTermsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/terms_content"
                android:textSize="12sp"
                android:textColor="@android:color/black"
                android:layout_marginBottom="24dp" />

            <!-- Privacy Policy Section -->
            <TextView
                android:id="@+id/tvPrivacyTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/privacy_policy"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary_purple"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvPrivacyContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/privacy_content"
                android:textSize="12sp"
                android:textColor="@android:color/black" />

        </LinearLayout>
    </ScrollView>

    <!-- Acceptance Checkbox -->
    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cbAcceptTerms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/i_accept_terms_and_privacy"
        android:textSize="14sp"
        android:textColor="@android:color/black"
        android:layout_marginBottom="16dp"
        app:buttonTint="@color/primary_purple" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="8dp">

        <Button
            android:id="@+id/btnDecline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/decline"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/error_red"
            android:backgroundTint="@android:color/transparent"
            android:layout_marginEnd="8dp"
            android:minHeight="64dp"
            android:minWidth="120dp"
            android:paddingVertical="16dp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <Button
            android:id="@+id/btnAccept"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/accept"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:backgroundTint="@color/primary_purple"
            android:minHeight="64dp"
            android:minWidth="120dp"
            android:paddingVertical="16dp"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

</LinearLayout>

