<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="600dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Title + Icon in a single row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_operator"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/operator_tower_24dp"
                app:tint="@color/primary_purple" />

        </LinearLayout>

        <!-- Operator Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/operator_name"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxStrokeColor="@color/primary_purple"
            app:hintTextColor="@color/primary_purple">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etOperatorName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@android:color/black"
                android:textColorHint="@color/text_on_light_glass" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Operator Code -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/operator_code"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxStrokeColor="@color/primary_purple"
            app:hintTextColor="@color/primary_purple">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etOperatorCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@android:color/black"
                android:textColorHint="@color/text_on_light_glass" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Operator Type Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/operator_type"
            android:textColor="@color/text_on_light_glass"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <!-- Operator Type Spinner -->
        <Spinner
            android:id="@+id/spOperatorType"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_light_background_with_arrow"
            android:paddingStart="12dp"
            android:paddingEnd="40dp"
            android:layout_marginBottom="12dp" />

        <!-- Operator Color Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/operator_color"
            android:textColor="@color/text_on_light_glass"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <!-- Operator Color Spinner -->
        <Spinner
            android:id="@+id/spOperatorColor"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/spinner_light_background_with_arrow"
            android:paddingStart="12dp"
            android:paddingEnd="40dp"
            android:layout_marginBottom="12dp" />

        <!-- Transfer Rate -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/transfer_rate"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusBottomEnd="8dp"
            app:boxStrokeColor="@color/primary_purple"
            app:hintTextColor="@color/primary_purple">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTransferRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="0.0"
                android:textColor="@android:color/black"
                android:textColorHint="@color/text_on_light_glass" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Active Checkbox -->
        <CheckBox
            android:id="@+id/cbEnabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/operator_enabled"
            android:textColor="@android:color/black"
            android:checked="true"
            android:layout_marginBottom="8dp" />

        <!-- Add Action Button (hidden by default) -->
        <Button
            android:id="@+id/btnAddAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_action"
            android:visibility="gone"
            android:background="@drawable/button_primary"
            android:textColor="@color/white" />

    </LinearLayout>

</ScrollView>
