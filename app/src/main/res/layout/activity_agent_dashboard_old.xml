<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Language Selection -->
        <include layout="@layout/language_selector" />

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/primary_blue"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_agent"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvUserInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/role_agent"
                android:textSize="16sp"
                android:textColor="@color/text_white"
                android:alpha="0.9" />

        </LinearLayout>

        <!-- Stats Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/tvStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:text="@string/my_stats"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Agent Actions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/agent_operations"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnCustomers"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/manage_customers"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:background="@drawable/button_primary"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnCashRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/cash_register"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:background="@drawable/button_primary"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnBuyCredit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/buy_virtual_credit"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:background="@drawable/button_primary"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnTransactions"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/process_transactions"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:background="@drawable/button_primary"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnReports"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/my_reports"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:background="@drawable/button_secondary"
            android:layout_marginBottom="24dp" />

        <!-- Logout Button -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/logout"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue"
            android:background="@drawable/button_outline"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</ScrollView>
