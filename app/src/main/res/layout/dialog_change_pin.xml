<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/card_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/current_pin"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etCurrentPin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/edittext_background"
        android:hint="@string/enter_current_pin_hint"
        android:inputType="numberPassword"
        android:maxLength="6"
        android:padding="16dp"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/new_pin"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etNewPin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/edittext_background"
        android:hint="@string/enter_new_pin_hint"
        android:inputType="numberPassword"
        android:maxLength="6"
        android:padding="16dp"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/confirm_new_pin"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etConfirmPin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/edittext_background"
        android:hint="@string/confirm_new_pin_hint"
        android:inputType="numberPassword"
        android:maxLength="6"
        android:padding="16dp"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:layout_marginBottom="8dp" />

</LinearLayout>
